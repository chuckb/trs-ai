# Variables for systemd-repart when formatting vfat (ESP). Raspberry Pi firmware is picky
# about BPB logical sector size; 512 matches typical SD expectations.
#
# Optional: source from shell scripts that invoke systemd-repart with matching vfat options.
# appliance/mkosi/mkosi.conf [Build] Environment= must keep the same key=value — mkosi does
# not read this file automatically.
SYSTEMD_REPART_MKFS_OPTIONS_VFAT='-S 512'
